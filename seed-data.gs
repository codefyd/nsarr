/**
 * دالة رئيسية لملء جميع الصفحات بأمثلة بيانات
 * استخدم هذه الدالة بعد تشغيل setupSpreadsheet مباشرة
 */
function seedAllData() {
  try {
    Logger.log('بدء ملء البيانات الافتراضية...');
    
    seedStudents();
    Logger.log('✓ تم إضافة الطلاب');
    
    seedRequests();
    Logger.log('✓ تم إضافة الطلبات الواردة');
    
    seedTeacherNotes();
    Logger.log('✓ تم إضافة ملاحظات المعلمين');
    
    seedEducationalWarnings();
    Logger.log('✓ تم إضافة الإنذارات التعليمية');
    
    seedAdministrativeWarnings();
    Logger.log('✓ تم إضافة الإنذارات الإدارية');
    
    Logger.log('✅ تم ملء جميع البيانات الافتراضية بنجاح!');
    return { success: true, message: 'تم ملء البيانات بنجاح' };
  } catch (error) {
    Logger.log('❌ خطأ: ' + error.message);
    return { success: false, error: error.message };
  }
}

