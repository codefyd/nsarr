// ============================================================================
// دالة حذف جميع البيانات الافتراضية
// ============================================================================

function clearAllData() {
  try {
    Logger.log('بدء حذف جميع البيانات...');
    
    clearSheet(أسماء_الصفحات.البيانات);
    Logger.log('✓ تم حذف الطلاب');
    
    clearSheet(أسماء_الصفحات.الطلبات_الواردة);
    Logger.log('✓ تم حذف الطلبات');
    
    clearSheet(أسماء_الصفحات.ملاحظات_المعلمين);
    Logger.log('✓ تم حذف الملاحظات');
    
    clearSheet(أسماء_الصفحات.الإنذارات_التعليمية);
    Logger.log('✓ تم حذف الإنذارات التعليمية');
    
    clearSheet(أسماء_الصفحات.الإنذارات_الإدارية);
    Logger.log('✓ تم حذف الإنذارات الإدارية');
    
    Logger.log('✅ تم حذف جميع البيانات بنجاح!');
    return { success: true, message: 'تم حذف البيانات بنجاح' };
  } catch (error) {
    Logger.log('❌ خطأ: ' + error.message);
    return { success: false, error: error.message };
  }
}

function clearSheet(sheetName) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
  if (!sheet) return;
  
  const lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    sheet.deleteRows(2, lastRow - 1);
  }
}

// ============================================================================
// دالة إعادة تعيين النظام بالكامل
// ============================================================================

function resetSystem() {
  try {
    Logger.log('بدء إعادة تعيين النظام بالكامل...');
    
    clearAllData();
    Logger.log('✓ تم حذف البيانات');
    
    setupSpreadsheet();
    Logger.log('✓ تم إعادة إنشاء الجداول');
    
    seedAllData();
    Logger.log('✓ تم ملء البيانات الافتراضية');
    
    Logger.log('✅ تم إعادة تعيين النظام بنجاح!');
    return { success: true, message: 'تم إعادة تعيين النظام بنجاح' };
  } catch (error) {
    Logger.log('❌ خطأ: ' + error.message);
    return { success: false, error: error.message };
  }
}
