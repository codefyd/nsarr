// ============================================================================
// الثوابت والإعدادات
// ============================================================================

const أسماء_الصفحات = {
  البيانات: 'البيانات',
  الطلبات_الواردة: 'الطلبات الواردة',
  الإنذارات_التعليمية: 'الإنذارات التعليمية',
  الإنذارات_الإدارية: 'الإنذارات الإدارية',
  الإعدادات: 'الإعدادات',
  الجلسات: 'النظام - الجلسات',
  سجل_العمليات: 'النظام - سجل العمليات',
  ملاحظات_المعلمين: 'ملاحظات المعلمين'
};

const الأدوار = {
  مدير: 'مدير',
  مشرف_إداري: 'مشرف إداري',
  مشرف_تعليمي: 'مشرف تعليمي',
  معلم: 'معلم'
};

const مدة_الجلسة_بالساعات = 12;

// ============================================================================
// دالة doGet - نقطة الدخول الرئيسية للتطبيق
// ============================================================================

function doGet(e) {
  try {
    // الحصول على ملف HTML الرئيسي
    const html = HtmlService.createHtmlOutputFromFile('index')
      .setTitle('نظام مجمع النصار')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no')
      .addMetaTag('charset', 'UTF-8')
      .addMetaTag('description', 'نظام متكامل لإدارة مجمع حلقات تحفيظ القرآن الكريم')
      .addMetaTag('theme-color', '#0d6efd')
      .setWidth(100)
      .setHeight(100);
    
    return html;
  } catch (error) {
    return HtmlService.createHtmlOutput('<h1>خطأ في تحميل التطبيق</h1><p>' + error.message + '</p>');
  }
}

// ============================================================================
// دالة doPost - معالجة الطلبات
// ============================================================================

function doPost(e) {
  try {
    const action = قراءة_بارامتر(e, 'action');
    switch (action) {
      // عمليات المستخدم
      case 'login': 
        return الرد({ success: true, data: login_(قراءة_بارامتر(e, 'رمز الدخول')) });
      case 'logout': 
        return الرد({ success: true, data: logout_(قراءة_بارامتر(e, 'token')) });
      
      // عمليات التسجيل والبيانات
      case 'registerStudent': 
        return الرد({ success: true, data: registerStudent_(e) });
      case 'getStudentData': 
        return الرد({ success: true, data: getStudentData_(e) });
      case 'requestStudentUpdate': 
        return الرد({ success: true, data: requestStudentUpdate_(e) });
      
      // عمليات لوحة التحكم
      case 'getDashboardBundle': 
        return الرد({ success: true, data: getDashboardBundle_(قراءة_بارامتر(e, 'token')) });
      case 'saveStudent': 
        return الرد({ success: true, data: saveStudent_(قراءة_بارامتر(e, 'token'), e) });
      case 'bulkUpdateStudents': 
        return الرد({ success: true, data: bulkUpdateStudents_(قراءة_بارامتر(e, 'token'), e) });
      case 'processRequest': 
        return الرد({ success: true, data: processRequest_(قراءة_بارامتر(e, 'token'), e) });
      
      // عمليات الملاحظات والإنذارات
      case 'addTeacherNote': 
        return الرد({ success: true, data: addTeacherNote_(قراءة_بارامتر(e, 'token'), e) });
      case 'addEducationalWarning': 
        return الرد({ success: true, data: addEducationalWarning_(قراءة_بارامتر(e, 'token'), e) });
      case 'generateAdministrativeWarnings': 
        return الرد({ success: true, data: generateAdministrativeWarnings_(قراءة_بارامتر(e, 'token')) });
      case 'completeAdministrativeWarning': 
        return الرد({ success: true, data: completeAdministrativeWarning_(قراءة_بارامتر(e, 'token'), e) });
      
      // عمليات الإعدادات
      case 'saveSettingCategory': 
        return الرد({ success: true, data: saveSettingCategory_(قراءة_بارامتر(e, 'token'), e) });
      
      // عمليات النظام
      case 'setupSpreadsheet': 
        return الرد({ success: true, data: setupSpreadsheet() });
      
      default: 
        return الرد({ success: false, error: 'أمر غير معروف: ' + action });
    }
  } catch (error) {
    return الرد({ success: false, error: error.message || String(error) });
  }
}

// ============================================================================
// وظائف المصادقة والجلسات
// ============================================================================

function login_(رمز_الدخول) {
  if (!رمز_الدخول) throw new Error('رمز الدخول مطلوب');
  
  const المستخدمون = الحصول_على_كل_الإعدادات()['المستخدمون'] || [];
  const المستخدم = المستخدمون.find(item => 
    String(item['رمز الدخول']) === String(رمز_الدخول) && 
    item['نشط'] !== false
  );
  
  if (!المستخدم) throw new Error('رمز الدخول غير صحيح');
  
  const token = Utilities.getUuid();
  إضافة_سجل(أسماء_الصفحات.الجلسات, {
    token: token,
    'اسم المستخدم': المستخدم['الاسم'],
    'الدور': المستخدم['الوظيفة'],
    'الحلقة': المستخدم['الحلقة'] || '',
    'وقت الإنشاء': الآن(),
    'وقت الانتهاء': new Date(Date.now() + مدة_الجلسة_بالساعات * 3600000).toISOString(),
    'نشط': 'نعم'
  });
  
  تسجيل_عملية('تسجيل دخول', 'تم تسجيل دخول المستخدم', المستخدم['الاسم'], المستخدم['الوظيفة'], {});
  
  return { 
    token: token, 
    name: المستخدم['الاسم'], 
    role: المستخدم['الوظيفة'],
    circle: المستخدم['الحلقة'] || ''
  };
}

function logout_(token) {
  if (!token) return { message: 'تم' };
  
  const الصفحة = صفحة_كسجلات(أسماء_الصفحات.الجلسات);
  const index = الصفحة.السجلات.findIndex(r => r['token'] === token && r['نشط'] === 'نعم');
  
  if (index > -1) {
    الصفحة.ورقة.getRange(index + 2, الصفحة.فهرسة['نشط']).setValue('لا');
  }
  
  return { message: 'تم تسجيل الخروج' };
}

function تحقق_الجلسة(token) {
  if (!token) throw new Error('الجلسة غير موجودة');
  
  const sessions = صفحة_كسجلات(أسماء_الصفحات.الجلسات).السجلات;
  const الجلسة = sessions.find(r => 
    r['token'] === token && 
    r['نشط'] === 'نعم' && 
    new Date(r['وقت الانتهاء']).getTime() > Date.now()
  );
  
  if (!الجلسة) throw new Error('انتهت الجلسة أو لا توجد صلاحية');
  
  return الجلسة;
}

// ============================================================================
// وظائف التسجيل والبيانات
// ============================================================================

function registerStudent_(e) {
  const البيانات = قراءة_الحقول(e, [
    'اسم الطالب ثلاثي',
    'هوية الطالب',
    'رقم جوال الطالب',
    'تاريخ ميلاد الطالب',
    'العنوان / الحي',
    'المرحلة الدراسية',
    'الصف الدراسي',
    'اسم ولي الأمر ثلاثي',
    'رقم جوال ولي الأمر',
    'رقم هوية ولي الأمر',
    'صلة ولي الأمر'
  ]);
  
  تحقق_تسجيل(البيانات);
  
  const الطلبات = صفحة_كسجلات(أسماء_الصفحات.الطلبات_الواردة).السجلات;
  const موجود = الطلبات.find(r => 
    r['هوية الطالب'] === البيانات['هوية الطالب'] && 
    ['جديد', 'انتظار', 'تعديل جديد'].includes(r['حالة الطلب'])
  );
  
  if (موجود) throw new Error('يوجد طلب سابق مفتوح لهذا الطالب');
  
  const رقم_الطلب = معرف('طلب');
  إضافة_سجل(أسماء_الصفحات.الطلبات_الواردة, Object.assign({
    'رقم الطلب': رقم_الطلب,
    'نوع الطلب': 'تسجيل',
    'حالة الطلب': 'جديد',
    'تاريخ الطلب': الآن(),
    'سبب الرفض': '',
    'الحقل المطلوب تعديله': '',
    'القيمة السابقة': '',
    'القيمة الجديدة': '',
    'الحلقة المقترحة': '',
    'ملاحظات': قراءة_بارامتر(e, 'ملاحظات') || '',
    'تمت المعالجة بواسطة': '',
    'تاريخ المعالجة': ''
  }, البيانات));
  
  تسجيل_عملية('طلب تسجيل', 'تم إرسال طلب تسجيل جديد', null, null, { 
    'رقم الطلب': رقم_الطلب, 
    'هوية الطالب': البيانات['هوية الطالب'] 
  });
  
  return { 'رقم الطلب': رقم_الطلب };
}

function getStudentData_(e) {
  const هوية = قراءة_بارامتر(e, 'هوية الطالب');
  const جوال = قراءة_بارامتر(e, 'رقم جوال ولي الأمر');
  
  if (!هوية && !جوال) throw new Error('أدخل هوية الطالب أو رقم جوال ولي الأمر');
  
  const الطلاب = صفحة_كسجلات(أسماء_الصفحات.البيانات).السجلات;
  const الطالب = الطلاب.find(r => 
    (هوية && r['هوية الطالب'] === هوية) || 
    (جوال && r['رقم جوال ولي الأمر'] === جوال)
  );
  
  if (!الطالب) throw new Error('لم يتم العثور على الطالب');
  
  return الطالب;
}

