  const الحقل = قراءة_بارامتر(e, 'الحقل المطلوب تعديله');
  const القيمة_الجديدة = قراءة_بارامتر(e, 'القيمة الجديدة');
  const ملاحظات = قراءة_بارامتر(e, 'ملاحظات') || '';
  
  const الطلاب = صفحة_كسجلات(أسماء_الصفحات.البيانات).السجلات;
