// ============================================================================
// وظائف مساعدة
// ============================================================================

function الحصول_على_كل_الإعدادات() {
  const rows = صفحة_كسجلات(أسماء_الصفحات.الإعدادات).السجلات
    .filter(r => r['نشط'] !== 'لا');
  const out = {};
  rows.forEach(r => { 
    out[r['الفئة']] = محاولة_تحويل_JSON(r['القيمة_JSON']); 
  });
  const lists = out['القوائم'] || {};
  Object.keys(lists).forEach(k => { 
    out[k] = lists[k]; 
  });
  return out;
}

function صفحة_كسجلات(اسم_الصفحة) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(اسم_الصفحة);
  if (!sheet) throw new Error('الصفحة غير موجودة: ' + اسم_الصفحة);
  
  const values = sheet.getDataRange().getValues();
  if (!values.length) return { ورقة: sheet, السجلات: [], فهرسة: {} };
  
  const headers = values[0];
  const indexMap = {};
  headers.forEach((h, i) => indexMap[h] = i + 1);
  
  const records = values.slice(1)
    .filter(row => row.some(v => v !== ''))
    .map(row => {
      const item = {};
      headers.forEach((h, i) => item[h] = row[i]);
      return item;
    });
  
  return { ورقة: sheet, السجلات: records, فهرسة: indexMap, الأعمدة: headers };
}

function إضافة_سجل(اسم_الصفحة, object) {
  const page = صفحة_كسجلات(اسم_الصفحة);
  const row = page.الأعمدة.map(h => typeof object[h] === 'undefined' ? '' : object[h]);
  page.ورقة.appendRow(row);
}

function تحديث_سجل(اسم_الصفحة, indexZeroBased, object) {
  const page = صفحة_كسجلات(اسم_الصفحة);
  const row = page.الأعمدة.map(h => typeof object[h] === 'undefined' ? '' : object[h]);
  page.ورقة.getRange(indexZeroBased + 2, 1, 1, row.length).setValues([row]);
}

function ضمان_رأس_الصفحة(صفحة, الأعمدة) {
  if (صفحة.getLastRow() === 0) {
    صفحة.appendRow(الأعمدة);
    return;
  }
  const width = Math.max(صفحة.getLastColumn(), الأعمدة.length);
  const current = صفحة.getRange(1, 1, 1, width).getValues()[0];
  let changed = false;
  الأعمدة.forEach((h, i) => {
    if (current[i] !== h) { current[i] = h; changed = true; }
  });
  if (changed) صفحة.getRange(1, 1, 1, الأعمدة.length).setValues([الأعمدة]);
}

function قراءة_بارامتر(e, name) {
  return e && e.parameter && typeof e.parameter[name] !== 'undefined' ? e.parameter[name] : '';
}

function قراءة_الحقول(e, keys) {
  const out = {};
  keys.forEach(k => out[k] = قراءة_بارامتر(e, k));
  return out;
}

function تحقق_تسجيل(بيانات) {
  if (!بيانات['اسم الطالب ثلاثي']) throw new Error('اسم الطالب مطلوب');
  if (!/^\d{8,12}$/.test(String(بيانات['هوية الطالب'] || ''))) throw new Error('هوية الطالب يجب أن تكون من 8 إلى 12 رقم');
  if (بيانات['رقم جوال الطالب'] && !/^\d{10}$/.test(String(بيانات['رقم جوال الطالب']))) throw new Error('رقم جوال الطالب يجب أن يكون 10 أرقام');
  if (!/^\d{10}$/.test(String(بيانات['رقم جوال ولي الأمر'] || ''))) throw new Error('رقم جوال ولي الأمر يجب أن يكون 10 أرقام');
}

function السماح_للأدوار(الجلسة, أدوار) {
  if (!أدوار.includes(الجلسة['الدور'])) throw new Error('لا توجد صلاحية');
}

function محاولة_تحويل_JSON(text) { 
  try { 
    return JSON.parse(text); 
  } catch (e) { 
    return text; 
  } 
}

function الآن() { 
  return new Date().toISOString(); 
}

function معرف(prefix) { 
  return prefix + '_' + new Date().getTime() + '_' + Math.floor(Math.random() * 10000); 
}

function مقارنة_زمنية_تنازلية(field) { 
  return function(a, b) { 
    return String(b[field] || '').localeCompare(String(a[field] || '')); 
  }; 
}

function تسجيل_عملية(العملية, الوصف, اسم_المستخدم, الدور, البيانات) {
  إضافة_سجل(أسماء_الصفحات.سجل_العمليات, {
    id: معرف('log'),
    'العملية': العملية,
    'الوصف': الوصف,
    'اسم المستخدم': اسم_المستخدم || '',
    'الدور': الدور || '',
    'التاريخ': الآن(),
    'البيانات_JSON': JSON.stringify(البيانات || {})
  });
}

function الرد(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}
