    'رقم الطلب': معرف('تعديل'),
    'نوع الطلب': 'تعديل بيانات',
    'اسم الطالب ثلاثي': الطالب['اسم الطالب ثلاثي'],
    'هوية الطالب': الطالب['هوية الطالب'],
    'رقم جوال الطالب': الطالب['رقم جوال الطالب'],
    'تاريخ ميلاد الطالب': الطالب['تاريخ ميلاد الطالب'],
    'العنوان / الحي': الطالب['العنوان / الحي'],
    'المرحلة الدراسية': الطالب['المرحلة الدراسية'],
    'الصف الدراسي': الطالب['الصف الدراسي'],
    'اسم ولي الأمر ثلاثي': الطالب['اسم ولي الأمر ثلاثي'],
    'رقم جوال ولي الأمر': الطالب['رقم جوال ولي الأمر'],
    'رقم هوية ولي الأمر': الطالب['رقم هوية ولي الأمر'],
    'صلة ولي الأمر': الطالب['صلة ولي الأمر'],
    'حالة الطلب': 'تعديل جديد',
    'تاريخ الطلب': الآن(),
    'سبب الرفض': '',
    'الحقل المطلوب تعديله': الحقل,
