// ============================================================================
// وظائف لوحة التحكم
// ============================================================================

function getDashboardBundle_(token) {
  const الجلسة = تحقق_الجلسة(token);
  const كل_الإعدادات = الحصول_على_كل_الإعدادات();
  
  const الطلاب = صفحة_كسجلات(أسماء_الصفحات.البيانات).السجلات;
  const الطلبات = صفحة_كسجلات(أسماء_الصفحات.الطلبات_الواردة).السجلات
    .sort(مقارنة_زمنية_تنازلية('تاريخ الطلب'));
  const الإنذارات_التعليمية = صفحة_كسجلات(أسماء_الصفحات.الإنذارات_التعليمية).السجلات
    .sort(مقارنة_زمنية_تنازلية('تاريخ الإنذار'));
  const الإنذارات_الإدارية = صفحة_كسجلات(أسماء_الصفحات.الإنذارات_الإدارية).السجلات
    .sort(مقارنة_زمنية_تنازلية('تاريخ الإنذار'));
  const الملاحظات = صفحة_كسجلات(أسماء_الصفحات.ملاحظات_المعلمين).السجلات
    .sort(مقارنة_زمنية_تنازلية('تاريخ الإنشاء'));
  const السجل = صفحة_كسجلات(أسماء_الصفحات.سجل_العمليات).السجلات
    .slice(0, 200)
    .sort(مقارنة_زمنية_تنازلية('التاريخ'));

  // تصفية الطلاب حسب الدور
  const طلاب_مرئيون = الجلسة['الدور'] === الأدوار.معلم
    ? الطلاب.filter(s => (s['الحلقة'] || '') === (الجلسة['الحلقة'] || ''))
    : الطلاب;

  return {
    'الإعدادات': كل_الإعدادات,
    'الطلاب': طلاب_مرئيون,
    'الطلبات': الطلبات,
    'الإنذارات_التعليمية': الإنذارات_التعليمية,
    'الإنذارات_الإدارية': الإنذارات_الإدارية,
    'الملاحظات': الملاحظات,
    'السجل': السجل,
    'الإحصائيات': {
      'إجمالي الطلاب': طلاب_مرئيون.length,
      'الطلبات الجديدة': الطلبات.filter(r => r['حالة الطلب'] === 'جديد').length,
      'الإنذارات الجديدة': الإنذارات_التعليمية.filter(r => r['الإجراء الحالي'] !== 'مكتمل').length
    }
  };
}

function saveStudent_(token, e) {
  const الجلسة = تحقق_الجلسة(token);
  السماح_للأدوار(الجلسة, [الأدوار.مشرف_إداري, الأدوار.مدير]);
  
  const هوية = قراءة_بارامتر(e, 'هوية الطالب');
  const البيانات = قراءة_الحقول(e, [
    'اسم الطالب ثلاثي',
    'رقم جوال الطالب',
    'تاريخ ميلاد الطالب',
    'العنوان / الحي',
    'المرحلة الدراسية',
    'الصف الدراسي',
    'الحلقة',
    'مجموع الحفظ',
    'حالة الطالب'
  ]);
  
  const الطلاب = صفحة_كسجلات(أسماء_الصفحات.البيانات);
  const index = الطلاب.السجلات.findIndex(r => r['هوية الطالب'] === هوية);
  
  if (index === -1) throw new Error('الطالب غير موجود');
  
  تحديث_سجل(أسماء_الصفحات.البيانات, index, Object.assign(
    الطلاب.السجلات[index],
    البيانات,
    { 'تاريخ التحديث': الآن(), 'بواسطة التحديث': الجلسة['اسم المستخدم'] }
  ));
  
  تسجيل_عملية('تحديث بيانات طالب', 'تم تحديث بيانات الطالب', الجلسة['اسم المستخدم'], الجلسة['الدور'], 
    { 'هوية الطالب': هوية });
  
  return { message: 'تم' };
}

function bulkUpdateStudents_(token, e) {
  const الجلسة = تحقق_الجلسة(token);
  السماح_للأدوار(الجلسة, [الأدوار.مشرف_إداري, الأدوار.مدير]);
  
  const الهويات = JSON.parse(قراءة_بارامتر(e, 'الهويات') || '[]');
  const التحديثات = JSON.parse(قراءة_بارامتر(e, 'التحديثات') || '{}');
  
  const الطلاب = صفحة_كسجلات(أسماء_الصفحات.البيانات);
  
  الهويات.forEach(هوية => {
    const index = الطلاب.السجلات.findIndex(r => r['هوية الطالب'] === هوية);
    if (index > -1) {
      تحديث_سجل(أسماء_الصفحات.البيانات, index, Object.assign(
        الطلاب.السجلات[index],
        التحديثات,
        { 'تاريخ التحديث': الآن(), 'بواسطة التحديث': الجلسة['اسم المستخدم'] }
      ));
    }
  });
  
  تسجيل_عملية('تحديث جماعي', 'تم تحديث ' + الهويات.length + ' طالب', الجلسة['اسم المستخدم'], الجلسة['الدور'], 
    { 'عدد الطلاب': الهويات.length });
  
  return { message: 'تم' };
}

function processRequest_(token, e) {
  const الجلسة = تحقق_الجلسة(token);
  السماح_للأدوار(الجلسة, [الأدوار.مشرف_إداري, الأدوار.مدير]);
  
  const رقم_الطلب = قراءة_بارامتر(e, 'رقم الطلب');
  const الإجراء = قراءة_بارامتر(e, 'الإجراء');
  const الحلقة = قراءة_بارامتر(e, 'الحلقة') || '';
  const سبب_الرفض = قراءة_بارامتر(e, 'سبب الرفض') || '';
  
  const الطلبات = صفحة_كسجلات(أسماء_الصفحات.الطلبات_الواردة);
  const index = الطلبات.السجلات.findIndex(r => r['رقم الطلب'] === رقم_الطلب);
  
  if (index === -1) throw new Error('الطلب غير موجود');
  
  const الطلب = الطلبات.السجلات[index];
  
  if (الإجراء === 'قبول') {
    if (الطلب['نوع الطلب'] === 'تسجيل' && !الحلقة) throw new Error('يجب تحديد الحلقة');
    
    // إضافة الطالب للبيانات إذا كان تسجيل جديد
    if (الطلب['نوع الطلب'] === 'تسجيل') {
      إضافة_سجل(أسماء_الصفحات.البيانات, {
        'id': معرف('student'),
        'اسم الطالب ثلاثي': الطلب['اسم الطالب ثلاثي'],
        'هوية الطالب': الطلب['هوية الطالب'],
        'رقم جوال الطالب': الطلب['رقم جوال الطالب'],
        'تاريخ ميلاد الطالب': الطلب['تاريخ ميلاد الطالب'],
        'العنوان / الحي': الطلب['العنوان / الحي'],
        'المرحلة الدراسية': الطلب['المرحلة الدراسية'],
        'الصف الدراسي': الطلب['الصف الدراسي'],
        'اسم ولي الأمر ثلاثي': الطلب['اسم ولي الأمر ثلاثي'],
        'رقم جوال ولي الأمر': الطلب['رقم جوال ولي الأمر'],
        'رقم هوية ولي الأمر': الطلب['رقم هوية ولي الأمر'],
        'صلة ولي الأمر': الطلب['صلة ولي الأمر'],
        'الحلقة': الحلقة,
        'مجموع الحفظ': 0,
        'حالة الطالب': 'نشط',
        'اسم المعلم': '',
        'عدد التأخرات': 0,
        'عدد الغيابات': 0,
        'عدد الغيابات بعذر': 0,
        'تاريخ الإنشاء': الآن(),
        'تاريخ التحديث': الآن(),
        'بواسطة الإنشاء': الجلسة['اسم المستخدم'],
        'بواسطة التحديث': الجلسة['اسم المستخدم']
      });
    }
    
    تحديث_سجل(أسماء_الصفحات.الطلبات_الواردة, index, Object.assign(الطلب, {
      'حالة الطلب': 'مقبول',
      'الحلقة المقترحة': الحلقة,
      'تمت المعالجة بواسطة': الجلسة['اسم المستخدم'],
      'تاريخ المعالجة': الآن()
    }));
  } else if (الإجراء === 'رفض') {
    if (!سبب_الرفض) throw new Error('يجب إدخال سبب الرفض');
    
    تحديث_سجل(أسماء_الصفحات.الطلبات_الواردة, index, Object.assign(الطلب, {
      'حالة الطلب': 'مرفوض',
      'سبب الرفض': سبب_الرفض,
      'تمت المعالجة بواسطة': الجلسة['اسم المستخدم'],
      'تاريخ المعالجة': الآن()
    }));
  } else if (الإجراء === 'انتظار') {
    تحديث_سجل(أسماء_الصفحات.الطلبات_الواردة, index, Object.assign(الطلب, {
      'حالة الطلب': 'انتظار'
    }));
  }
  
  تسجيل_عملية('معالجة طلب', 'تم ' + الإجراء + ' الطلب رقم ' + رقم_الطلب, الجلسة['اسم المستخدم'], الجلسة['الدور'], 
    { 'رقم الطلب': رقم_الطلب, 'الإجراء': الإجراء });
  
  return { message: 'تم' };
}

